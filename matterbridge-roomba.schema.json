{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Matterbridge Roomba",
  "description": "Matterbridge plugin for iRobot Roomba devices",
  "type": "object",
  "properties": {
    "name": {
      "description": "Plugin name",
      "type": "string"
    },
    "type": {
      "description": "Plugin type",
      "type": "string"
    },
    "email": {
      "title": "iRobot Account Email",
      "description": "Email address for iRobot cloud account. Optional if all devices are configured manually.",
      "type": "string"
    },
    "password": {
      "title": "iRobot Account Password",
      "description": "Password for iRobot cloud account. Optional if all devices are configured manually.",
      "type": "string"
    },
    "idleWatchInterval": {
      "title": "Idle Watch Interval (minutes)",
      "description": "How often to poll Roomba when idle, in minutes. Default: 15.",
      "type": "number",
      "default": 15
    },
    "devices": {
      "title": "Devices",
      "description": "Manual device configuration. Required when not using cloud credentials.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "blid", "robotpwd", "ipaddress"],
        "properties": {
          "name": {
            "title": "Device Name",
            "description": "Display name for this Roomba.",
            "type": "string"
          },
          "blid": {
            "title": "Robot ID (blid)",
            "description": "The Roomba's robot ID (blid).",
            "type": "string"
          },
          "robotpwd": {
            "title": "Robot Password",
            "description": "The local MQTT password for this Roomba.",
            "type": "string"
          },
          "ipaddress": {
            "title": "IP Address",
            "description": "Local IP address of this Roomba.",
            "type": "string"
          },
          "stopBehaviour": {
            "title": "Stop Behaviour",
            "description": "What to do when the robot is stopped: send home or just pause.",
            "type": "string",
            "enum": ["home", "pause"],
            "default": "home"
          },
          "idleWatchInterval": {
            "title": "Idle Watch Interval (minutes)",
            "description": "Override the global idle watch interval for this device.",
            "type": "number"
          },
          "missions": {
            "title": "Named Missions",
            "description": "Named cleaning missions available as clean modes.",
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "pmap_id", "user_pmapv_id"],
              "properties": {
                "name": {
                  "title": "Mission Name",
                  "type": "string"
                },
                "pmap_id": {
                  "title": "Persistent Map ID",
                  "type": "string"
                },
                "user_pmapv_id": {
                  "title": "User Persistent Map Version ID",
                  "type": "string"
                },
                "ordered": {
                  "title": "Ordered",
                  "type": "number",
                  "default": 1
                },
                "favorite_id": {
                  "title": "Favorite ID",
                  "description": "Optional favorite_id to include with the start command.",
                  "type": "string"
                },
                "regions": {
                  "title": "Regions",
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["region_id", "type"],
                    "properties": {
                      "region_id": {
                        "title": "Region ID",
                        "type": "string"
                      },
                      "type": {
                        "title": "Region Type",
                        "type": "string",
                        "default": "rid"
                      },
                      "params": {
                        "title": "Region Params",
                        "type": "object",
                        "properties": {
                          "noAutoPasses": {
                            "title": "No Auto Passes",
                            "type": "boolean"
                          },
                          "twoPass": {
                            "title": "Two Pass",
                            "type": "boolean"
                          },
                          "carpetBoost": {
                            "title": "Carpet Boost",
                            "type": "boolean"
                          },
                          "vacHigh": {
                            "title": "High Vacuum",
                            "type": "boolean"
                          },
                          "gentleMode": {
                            "title": "Gentle Mode",
                            "type": "number"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
