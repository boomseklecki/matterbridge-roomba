{
  "name": "matterbridge-roomba",
  "version": "1.1.2",
  "description": "Matterbridge plugin for iRobot Roomba vacuum cleaners",
  "author": "Rashed97",
  "license": "Apache-2.0",
  "keywords": [
    "matter",
    "matterbridge",
    "matterbridge-plugin",
    "roomba",
    "irobot",
    "vacuum",
    "robotic-vacuum",
    "rvc",
    "homekit",
    "apple-home",
    "google-home",
    "smarthome",
    "dorita980"
  ],
  "type": "module",
  "main": "./dist/module.js",
  "types": "./dist/module.d.ts",
  "files": [
    "dist/",
    "matterbridge-roomba.schema.json",
    "matterbridge-roomba.config.json",
    "README.md",
    "ONBOARDING.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/Rashed97/matterbridge-roomba#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rashed97/matterbridge-roomba.git"
  },
  "bugs": {
    "url": "https://github.com/Rashed97/matterbridge-roomba/issues"
  },
  "engines": {
    "matterbridge": ">=3.6.1",
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "tsc && matterbridge -childbridge",
    "dev:link": "npm link matterbridge",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "dependencies": {
    "dorita980": "npm:@karlvr/dorita980@^3.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
